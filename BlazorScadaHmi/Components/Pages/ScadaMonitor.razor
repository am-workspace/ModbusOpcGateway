@page "/"
@page "/monitor"
@inject SharedData SharedData
@inject NavigationManager Navigation
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>SCADA 监控面板</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">SCADA 监控面板</MudText>

@if (!_isConnected)
{
    <MudAlert Severity="Severity.Warning" Icon="@Icons.Material.Filled.Sync">
        <MudText Typo="Typo.subtitle1">正在连接服务器...</MudText>
        <MudText Typo="Typo.caption">SignalR 连接中，请稍候</MudText>
    </MudAlert>
}
else if (_connectionState == HubConnectionState.Reconnecting)
{
    <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.SyncProblem">
        <MudText Typo="Typo.subtitle1">连接中断，正在重连...</MudText>
        <MudText Typo="Typo.caption">网络波动，尝试恢复连接</MudText>
    </MudAlert>
}
else if (_connectionState == HubConnectionState.Disconnected && _hasConnectedBefore)
{
    <MudAlert Severity="Severity.Error" Icon="@Icons.Material.Filled.CloudOff">
        <div class="d-flex align-items-center justify-content-between w-100">
            <div>
                <MudText Typo="Typo.subtitle1">连接已断开</MudText>
                <MudText Typo="Typo.caption">无法连接到服务器，请检查网络</MudText>
            </div>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" OnClick="ReconnectAsync">重新连接</MudButton>
        </div>
    </MudAlert>
}

<MudGrid Class="mt-4">
    <MudItem xs="12" md="4">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">实时数据</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIconButton Icon="@Icons.Material.Filled.Thermostat" Color="Color.Primary" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudStack Spacing="3">
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">温度 (°C)</MudText>
                        <MudText Typo="Typo.h3" Color="Color.Primary">@_temperature.ToString("F1")</MudText>
                    </div>
                    <MudDivider />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">压力 (kPa)</MudText>
                        <MudText Typo="Typo.h3" Color="Color.Success">@_pressure.ToString("F1")</MudText>
                    </div>
                    <MudDivider />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">设备状态</MudText>
                        <MudText Typo="Typo.h5" Color="@(_status ? Color.Success : Color.Error)">
                            @(_status ? "运行中" : "已停止")
                        </MudText>
                    </div>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">控制面板</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Info" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudStack Spacing="3">
                    <MudSelect T="int" Label="模拟模式" @bind-Value="_selectedMode" @bind-Value:after="OnModeChanged">
                        <MudSelectItem Value="0">Random (随机)</MudSelectItem>
                        <MudSelectItem Value="1">Trend (趋势)</MudSelectItem>
                        <MudSelectItem Value="2">Frozen (冻结)</MudSelectItem>
                    </MudSelect>
                    <div>
                        <MudText Typo="Typo.caption">噪声系数: @_noise.ToString("F1")</MudText>
                        <MudSlider T="float" Min="0" Max="10" Step="0.1f" Value="_noise" ValueChanged="async (value) => { _noise = value; await OnNoiseChanged(); }" />
                    </div>
                    <div>
                        <MudText Typo="Typo.caption">响应延迟 (ms): @_delayMs</MudText>
                        <MudSlider T="int" Min="0" Max="5000" Step="100" Value="_delayMs" ValueChanged="async (value) => { _delayMs = value; await OnDelayChanged(); }" />
                    </div>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">故障注入</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIconButton Icon="@Icons.Material.Filled.BugReport" Color="Color.Warning" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudStack Spacing="2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Filled.CheckCircle" OnClick="ResumeNormal">
                        恢复正常
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Warning" OnClick="InjectFaultyTemperature">
                        异常温度 (999.9°C)
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Warning" OnClick="InjectFaultyPressure">
                        异常压力 (-50.0 kPa)
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Pause" OnClick="FreezeData">
                        冻结数据
                    </MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private float _temperature;
    private float _pressure;
    private bool _status;
    private int _selectedMode;
    private float _noise;
    private int _delayMs;

    private HubConnection? _hubConnection;
    private bool _isConnected;
    private HubConnectionState _connectionState;
    private bool _hasConnectedBefore;

    protected override async Task OnInitializedAsync()
    {
        // 创建 SignalR 连接
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/scadahub"))
            .WithAutomaticReconnect([TimeSpan.Zero, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(30)])
            .Build();

        // 监听连接状态变化
        _hubConnection.Reconnecting += error =>
        {
            _connectionState = HubConnectionState.Reconnecting;
            InvokeAsync(StateHasChanged);
            return Task.CompletedTask;
        };

        _hubConnection.Reconnected += connectionId =>
        {
            _connectionState = HubConnectionState.Connected;
            InvokeAsync(StateHasChanged);
            return Task.CompletedTask;
        };

        _hubConnection.Closed += error =>
        {
            _connectionState = HubConnectionState.Disconnected;
            _isConnected = false;
            InvokeAsync(StateHasChanged);
            return Task.CompletedTask;
        };

        // 注册数据更新回调
        _hubConnection.On<DataSnapshot>("DataUpdated", snapshot =>
        {
            _temperature = snapshot.Temperature;
            _pressure = snapshot.Pressure;
            _status = snapshot.Status;
            _selectedMode = snapshot.Mode;
            _noise = snapshot.NoiseMultiplier;
            _delayMs = snapshot.ResponseDelayMs;
            InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
        _isConnected = true;
        _hasConnectedBefore = true;
        _connectionState = HubConnectionState.Connected;

        // 获取初始数据
        var snapshot = await _hubConnection.InvokeAsync<DataSnapshot>("GetDataSnapshot");
        _temperature = snapshot.Temperature;
        _pressure = snapshot.Pressure;
        _status = snapshot.Status;
        _selectedMode = snapshot.Mode;
        _noise = snapshot.NoiseMultiplier;
        _delayMs = snapshot.ResponseDelayMs;
    }

    private async Task OnModeChanged()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.InvokeAsync("SetMode", _selectedMode);
        }
    }

    private async Task OnNoiseChanged()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.InvokeAsync("SetNoiseMultiplier", _noise);
        }
    }

    private async Task OnDelayChanged()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.InvokeAsync("SetResponseDelay", _delayMs);
        }
    }

    private async Task ResumeNormal()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.InvokeAsync("ResumeNormal");
            _selectedMode = 0;
        }
    }

    private async Task InjectFaultyTemperature()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.InvokeAsync("InjectFaultyTemperature");
        }
    }

    private async Task InjectFaultyPressure()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.InvokeAsync("InjectFaultyPressure");
        }
    }

    private async Task FreezeData()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.InvokeAsync("FreezeData");
            _selectedMode = 2;
        }
    }

    private async Task ReconnectAsync()
    {
        if (_hubConnection is not null)
        {
            try
            {
                await _hubConnection.StartAsync();
                _isConnected = true;
                _connectionState = HubConnectionState.Connected;

                // 重新获取数据
                var snapshot = await _hubConnection.InvokeAsync<DataSnapshot>("GetDataSnapshot");
                _temperature = snapshot.Temperature;
                _pressure = snapshot.Pressure;
                _status = snapshot.Status;
                _selectedMode = snapshot.Mode;
                _noise = snapshot.NoiseMultiplier;
                _delayMs = snapshot.ResponseDelayMs;
            }
            catch
            {
                // 连接失败，保持断开状态
                _connectionState = HubConnectionState.Disconnected;
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
