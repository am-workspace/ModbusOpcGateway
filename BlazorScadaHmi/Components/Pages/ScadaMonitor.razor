@page "/"
@page "/monitor"
@inject SharedData SharedData
@inject NavigationManager Navigation
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>SCADA 监控面板</PageTitle>

<h1>SCADA 监控面板</h1>

@if (!_isConnected)
{
    <div class="alert alert-warning d-flex align-items-center">
        <span class="spinner-border spinner-border-sm me-2"></span>
        <div>
            <strong>正在连接服务器...</strong>
            <div class="small">SignalR 连接中，请稍候</div>
        </div>
    </div>
}
else if (_connectionState == HubConnectionState.Reconnecting)
{
    <div class="alert alert-info d-flex align-items-center">
        <span class="spinner-border spinner-border-sm me-2"></span>
        <div>
            <strong>连接中断，正在重连...</strong>
            <div class="small">网络波动，尝试恢复连接</div>
        </div>
    </div>
}
else if (_connectionState == HubConnectionState.Disconnected && _hasConnectedBefore)
{
    <div class="alert alert-danger d-flex align-items-center justify-content-between">
        <div>
            <strong>连接已断开</strong>
            <div class="small">无法连接到服务器，请检查网络</div>
        </div>
        <button class="btn btn-sm btn-outline-danger" @onclick="ReconnectAsync">重新连接</button>
    </div>
}

<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5>实时数据</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">温度 (°C)</label>
                    <div class="display-4 text-primary">@_temperature.ToString("F1")</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">压力 (kPa)</label>
                    <div class="display-4 text-success">@_pressure.ToString("F1")</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">设备状态</label>
                    <div class="display-6 @(_status ? "text-success" : "text-danger")">
                        @(_status ? "运行中" : "已停止")
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h5>控制面板</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">模拟模式</label>
                    <select class="form-select" @bind="_selectedMode" @bind:after="OnModeChanged">
                        <option value="0">Random (随机)</option>
                        <option value="1">Trend (趋势)</option>
                        <option value="2">Frozen (冻结)</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">噪声系数: @_noise.ToString("F1")</label>
                    <input type="range" class="form-range" min="0" max="10" step="0.1" 
                           @bind="_noise" @bind:event="oninput" @bind:after="OnNoiseChanged" />
                </div>
                <div class="mb-3">
                    <label class="form-label">响应延迟 (ms): @_delayMs</label>
                    <input type="range" class="form-range" min="0" max="5000" step="100" 
                           @bind="_delayMs" @bind:event="oninput" @bind:after="OnDelayChanged" />
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-warning text-dark">
                <h5>故障注入</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <button class="btn btn-outline-success" @onclick="ResumeNormal">
                        恢复正常
                    </button>
                    <button class="btn btn-outline-danger" @onclick="InjectFaultyTemperature">
                        异常温度 (999.9°C)
                    </button>
                    <button class="btn btn-outline-danger" @onclick="InjectFaultyPressure">
                        异常压力 (-50.0 kPa)
                    </button>
                    <button class="btn btn-outline-warning" @onclick="FreezeData">
                        冻结数据
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private float _temperature;
    private float _pressure;
    private bool _status;
    private int _selectedMode;
    private float _noise;
    private int _delayMs;

    private HubConnection? _hubConnection;
    private bool _isConnected;
    private HubConnectionState _connectionState;
    private bool _hasConnectedBefore;

    protected override async Task OnInitializedAsync()
    {
        // 创建 SignalR 连接
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/scadahub"))
            .WithAutomaticReconnect([TimeSpan.Zero, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(30)])
            .Build();

        // 监听连接状态变化
        _hubConnection.Reconnecting += error =>
        {
            _connectionState = HubConnectionState.Reconnecting;
            InvokeAsync(StateHasChanged);
            return Task.CompletedTask;
        };

        _hubConnection.Reconnected += connectionId =>
        {
            _connectionState = HubConnectionState.Connected;
            InvokeAsync(StateHasChanged);
            return Task.CompletedTask;
        };

        _hubConnection.Closed += error =>
        {
            _connectionState = HubConnectionState.Disconnected;
            _isConnected = false;
            InvokeAsync(StateHasChanged);
            return Task.CompletedTask;
        };

        // 注册数据更新回调
        _hubConnection.On<DataSnapshot>("DataUpdated", snapshot =>
        {
            _temperature = snapshot.Temperature;
            _pressure = snapshot.Pressure;
            _status = snapshot.Status;
            _selectedMode = snapshot.Mode;
            _noise = snapshot.NoiseMultiplier;
            _delayMs = snapshot.ResponseDelayMs;
            InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
        _isConnected = true;
        _hasConnectedBefore = true;
        _connectionState = HubConnectionState.Connected;

        // 获取初始数据
        var snapshot = await _hubConnection.InvokeAsync<DataSnapshot>("GetDataSnapshot");
        _temperature = snapshot.Temperature;
        _pressure = snapshot.Pressure;
        _status = snapshot.Status;
        _selectedMode = snapshot.Mode;
        _noise = snapshot.NoiseMultiplier;
        _delayMs = snapshot.ResponseDelayMs;
    }

    private async Task OnModeChanged()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.InvokeAsync("SetMode", _selectedMode);
        }
    }

    private async Task OnNoiseChanged()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.InvokeAsync("SetNoiseMultiplier", _noise);
        }
    }

    private async Task OnDelayChanged()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.InvokeAsync("SetResponseDelay", _delayMs);
        }
    }

    private async Task ResumeNormal()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.InvokeAsync("ResumeNormal");
            _selectedMode = 0;
        }
    }

    private async Task InjectFaultyTemperature()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.InvokeAsync("InjectFaultyTemperature");
        }
    }

    private async Task InjectFaultyPressure()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.InvokeAsync("InjectFaultyPressure");
        }
    }

    private async Task FreezeData()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.InvokeAsync("FreezeData");
            _selectedMode = 2;
        }
    }

    private async Task ReconnectAsync()
    {
        if (_hubConnection is not null)
        {
            try
            {
                await _hubConnection.StartAsync();
                _isConnected = true;
                _connectionState = HubConnectionState.Connected;

                // 重新获取数据
                var snapshot = await _hubConnection.InvokeAsync<DataSnapshot>("GetDataSnapshot");
                _temperature = snapshot.Temperature;
                _pressure = snapshot.Pressure;
                _status = snapshot.Status;
                _selectedMode = snapshot.Mode;
                _noise = snapshot.NoiseMultiplier;
                _delayMs = snapshot.ResponseDelayMs;
            }
            catch
            {
                // 连接失败，保持断开状态
                _connectionState = HubConnectionState.Disconnected;
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
