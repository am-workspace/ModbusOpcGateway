@page "/"
@page "/monitor"
@inject SharedData SharedData
@rendermode InteractiveServer

<PageTitle>SCADA 监控面板</PageTitle>

<h1>SCADA 监控面板</h1>

<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5>实时数据</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">温度 (°C)</label>
                    <div class="display-4 text-primary">@_temperature.ToString("F1")</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">压力 (kPa)</label>
                    <div class="display-4 text-success">@_pressure.ToString("F1")</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">设备状态</label>
                    <div class="display-6 @(_status ? "text-success" : "text-danger")">
                        @(_status ? "运行中" : "已停止")
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h5>控制面板</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">模拟模式</label>
                    <select class="form-select" @bind="_selectedMode" @bind:after="OnModeChanged">
                        <option value="0">Random (随机)</option>
                        <option value="1">Trend (趋势)</option>
                        <option value="2">Frozen (冻结)</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">噪声系数: @_noise.ToString("F1")</label>
                    <input type="range" class="form-range" min="0" max="10" step="0.1" 
                           @bind="_noise" @bind:event="oninput" @bind:after="OnNoiseChanged" />
                </div>
                <div class="mb-3">
                    <label class="form-label">响应延迟 (ms): @_delayMs</label>
                    <input type="range" class="form-range" min="0" max="5000" step="100" 
                           @bind="_delayMs" @bind:event="oninput" @bind:after="OnDelayChanged" />
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-warning text-dark">
                <h5>故障注入</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <button class="btn btn-outline-success" @onclick="ResumeNormal">
                        恢复正常
                    </button>
                    <button class="btn btn-outline-danger" @onclick="InjectFaultyTemperature">
                        异常温度 (999.9°C)
                    </button>
                    <button class="btn btn-outline-danger" @onclick="InjectFaultyPressure">
                        异常压力 (-50.0 kPa)
                    </button>
                    <button class="btn btn-outline-warning" @onclick="FreezeData">
                        冻结数据
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private float _temperature;
    private float _pressure;
    private bool _status;
    private int _selectedMode;
    private float _noise;
    private int _delayMs;

    private System.Threading.Timer? _timer;

    protected override void OnInitialized()
    {
        UpdateDataFromSharedData();
        
        // 每秒刷新一次数据
        _timer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                UpdateDataFromSharedData();
                StateHasChanged();
            });
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    private void UpdateDataFromSharedData()
    {
        var snapshot = SharedData.Snapshot();
        _temperature = snapshot.Temp;
        _pressure = snapshot.Press;
        _status = snapshot.Status;
        _selectedMode = (int)SharedData.GetMode();
        _noise = SharedData.GetNoiseMultiplier();
        _delayMs = SharedData.GetResponseDelayMs();
    }

    private void OnModeChanged()
    {
        SharedData.SetMode((SharedData.SimulationMode)_selectedMode);
    }

    private void OnNoiseChanged()
    {
        SharedData.SetNoiseMultiplier(_noise);
    }

    private void OnDelayChanged()
    {
        SharedData.SetResponseDelay(_delayMs);
    }

    private void ResumeNormal()
    {
        SharedData.ResumeNormal();
        _selectedMode = 0;
    }

    private void InjectFaultyTemperature()
    {
        SharedData.InjectFaultyTemperature();
    }

    private void InjectFaultyPressure()
    {
        SharedData.InjectFaultyPressure();
    }

    private void FreezeData()
    {
        SharedData.FreezeData();
        _selectedMode = 2;
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}
