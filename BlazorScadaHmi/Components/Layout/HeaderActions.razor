@rendermode InteractiveServer
@using BlazorScadaHmi.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject UiStateService UiState
@implements IDisposable

<MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="DrawerToggle" />
<MudText Typo="Typo.h6" Class="ml-3">SCADA 监控系统</MudText>
<MudSpacer />
<MudIconButton Icon="@(UiState.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" Color="Color.Inherit" OnClick="@(() => UiState.SetDarkMode(!UiState.IsDarkMode))" Title="切换主题" />
<MudMenu Icon="@Icons.Material.Filled.Person" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
    <ChildContent>
        <MudMenuItem Disabled="true">
            <MudText Typo="Typo.caption">@_displayName</MudText>
            <MudText Typo="Typo.overline" Class="mud-text-secondary">@_role</MudText>
        </MudMenuItem>
        <MudDivider />
        <MudMenuItem>
            <form method="post" action="/api/logout" style="display:inline">
                <button type="submit" style="background:none;border:none;padding:0;font:inherit;cursor:pointer;color:inherit;display:flex;align-items:center;gap:8px">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg>
                    退出登录
                </button>
            </form>
        </MudMenuItem>
    </ChildContent>
</MudMenu>

@code {
    private string _displayName = "未登录";
    private string _role = "";

    protected override void OnInitialized()
    {
        UiState.OnChange += StateHasChanged;
        UpdateUserInfo();
    }

    public void Dispose() => UiState.OnChange -= StateHasChanged;

    private void DrawerToggle()
    {
        UiState.ToggleDrawer();
    }

    private void UpdateUserInfo()
    {
        if (AuthStateProvider is CustomAuthStateProvider customAuth)
        {
            var user = customAuth.GetCurrentUser();
            if (user != null)
            {
                _displayName = user.DisplayName;
                _role = user.Role.ToString();
            }
        }
    }
}
