{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Modbus": {
    "Enabled": true,
    "Host": "127.0.0.1",
    "Port": 5020,
    "PollIntervalMs": 1000,
    "Registers": [
      {
        "Address": 0,
        "Name": "Temperature",
        "Type": "HoldingRegister"
      },
      {
        "Address": 1,
        "Name": "Pressure",
        "Type": "HoldingRegister"
      },
      {
        "Address": 2,
        "Name": "Status",
        "Type": "HoldingRegister"
      }
    ]
  },
  "OpcUa": {
    "Enabled": true,
    "Endpoint": "opc.tcp://localhost:4840",
    "Nodes": [
      {
        "NodeId": "ns=2;s=Temperature",
        "Name": "Temperature"
      },
      {
        "NodeId": "ns=2;s=Pressure",
        "Name": "Pressure"
      },
      {
        "NodeId": "ns=2;s=Status",
        "Name": "Status"
      }
    ]
  },
  "Mqtt": {
    "Enabled": true,
    "Broker": "localhost",
    "Port": 1883,
    "TopicPrefix": "industrial",
    "ClientId": "PlcGateway",
    "Username": "",
    "Password": ""
  }
}
